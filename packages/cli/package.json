{
  "name": "@react-log-agent/cli",
  "version": "0.0.0",
  "description": "Terminal CLI agent for React Log Agent.",
  "type": "module",
  "license": "MIT",
  "author": "React Log Agent Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/react-log-agent/react-log-agent.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/react-log-agent/react-log-agent/issues"
  },
  "homepage": "https://github.com/react-log-agent/react-log-agent#readme",
  "keywords": [
    "react",
    "logging",
    "cli",
    "devtools",
    "websocket",
    "telemetry"
  ],
  "bin": {
    "react-log-agent": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --platform node",
    "typecheck": "tsc --noEmit --strict",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@react-log-agent/protocol": "0.0.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  }
}
