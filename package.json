{
  "name": "react-example",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "workspaces": [
    "packages/protocol",
    "packages/runtime",
    "packages/cli",
    "packages/sandbox"
  ],
  "scripts": {
    "dev": "vite --port=9090 --host=0.0.0.0",
    "dev:sandbox": "npm run dev --workspace @anilkrblt/sandbox",
    "build": "npm run build:packages && npm run build:app",
    "build:app": "vite build",
    "build:sandbox": "npm run build --workspace @anilkrblt/sandbox",
    "build:packages": "node scripts/build-packages.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "typecheck:sandbox": "npm run typecheck --workspace @anilkrblt/sandbox",
    "typecheck:packages": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@anilkrblt/protocol": "0.1.0",
    "@anilkrblt/runtime": "0.1.0",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.100.6",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^6.30.1",
    "react-syntax-highlighter": "^16.1.1",
    "shadcn": "^4.6.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@anilkrblt/cli": "0.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
